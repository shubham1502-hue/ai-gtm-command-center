# Copy this file to .env or export these variables in your shell.
# The app runs without keys using --provider mock.

# Gemini free-tier friendly default.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq fallback. Uses Groq's OpenAI-compatible API through stdlib HTTP.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Keep outreach draft-only unless you intentionally add an email sender.
OUTREACH_SEND_ENABLED=false

# Optional Google Sheets sync. This is free-tier friendly and keeps the workflow human-approved.
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET_NAME=Draft Queue
GOOGLE_SERVICE_ACCOUNT_JSON=
